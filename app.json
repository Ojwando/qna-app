{
  "expo": {
    "name": "Computer Studies Q&A",
    "slug": "qna-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "qnaapp",
    "userInterfaceStyle": "automatic",
    "owner": "ojwando",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ojwando.qnaapp"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/icon.png"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.ojwando.qnaapp"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-9553974808339903~5768301189"
        }
      ],
      "expo-web-browser"
    ],
    "assetBundlePatterns": [
      "**/*"
    ],
    "updates": {
      "enabled": false
    },
    "extra": {
      "eas": {
        "projectId": "90a72c55-77d9-4a3a-9ac7-5fe48f326513"
      }
    }
  }
}
